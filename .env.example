# Copy this file to .env and fill in the values. Never commit .env (it is gitignored).
# The same variables must be set in Vercel: Settings -> Environments -> Production -> Environment Variables.

# Firebase Admin service-account key.
# Either the raw service-account JSON on one line, or (easier) the base64 of that JSON file.
# Generate base64:  [Convert]::ToBase64String([IO.File]::ReadAllBytes("path\to\key.json"))
FIREBASE_SERVICE_ACCOUNT=

# Resend API key from https://resend.com -> API Keys (starts with re_)
RESEND_API_KEY=

# Inbox that receives the Approve/Deny emails.
# On Resend's free tier (no verified domain) this MUST equal the Resend signup email.
OWNER_EMAIL=

# Base URL used to build the approve/deny links in the owner email.
# Defaults to the live site if unset; set this only if you move to a custom domain.
PUBLIC_BASE_URL=https://haider-portfolio-jet.vercel.app

# Optional sender. Defaults to onboarding@resend.dev (works with no domain).
# FROM_EMAIL=Portfolio <onboarding@resend.dev>
